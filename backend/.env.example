# Smart Note Collab - Backend Environment Variables

# Server Port
PORT=3000

# MongoDB Connection String (MUST be provided)
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/smartnote

# JWT Secret Key for Auth and Sockets
JWT_SECRET=your_strong_random_secret_string_here

# Client URL for CORS
CLIENT_URL=http://localhost:5173
